# ==== MELUSTI BOT KONFIGURATION ====
# 1. Kopiere diese Datei zu ".env"
# 2. Trage eure Werte ein (README Schritt 2 erklärt, wo ihr sie findet)

DISCORD_TOKEN=dein_bot_token_hier
MELI_ID=482238928410116096
JUSTI_ID=585801317327437825
MELI_NAME=Meli
JUSTI_NAME=Justi

# Optional:
CHECKIN_HOUR=03
MORNING_HOUR=14
DB_PATH=melusti.db

# Optional: Cloud-Datenbank fürs Hosting (turso.tech, kostenlos). Wenn beide
# gesetzt sind, wird DB_PATH ignoriert und stattdessen die Cloud-DB genutzt
# (nötig für Hosts ohne dauerhafte Festplatte, z.B. Render Free Tier).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: Letterboxd-Auto-Sync (öffentliche Profile, kein Key nötig)
LETTERBOXD_MELI=
LETTERBOXD_JUSTI=

# Optional: Spotify-Playlist-Integration (developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: Valorant-Tracker
RIOT_API_KEY=
RIOT_ID_MELI=
RIOT_ID_JUSTI=
RIOT_REGION=eu
# Für den echten Rang (developer.riotgames.com kann das nicht liefern):
# Discord discord.gg/X3GaVkX2YN beitreten, Bot gibt den Key direkt.
HENRIKDEV_API_KEY=

# Optional: Steam-Import für Spiele-Tinder (kostenloser Key, sofort unter
# steamcommunity.com/dev/apikey). STEAM_ID_*: SteamID64 oder Vanity-Name
# aus der Profil-URL. Spieleliste im Profil muss auf "öffentlich" stehen.
STEAM_API_KEY=
STEAM_ID_MELI=
STEAM_ID_JUSTI=
